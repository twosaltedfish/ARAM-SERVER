# ===== aramgg 数据源（必填）=====
# 你的第三方 API Key（Bearer 鉴权）。仅存于服务器，切勿写入小程序前端。
DTODO_API_KEY=your_api_key_here

# ===== 服务配置 =====
# 监听端口（Nginx 反代到此端口）
PORT=3000

# SQLite 文件路径（相对 server.js 启动目录；可改绝对路径）
DB_PATH=./data/aram.db

# 是否拉取每个英雄的详情（champions/{id}.json）。
# 开(true)则每日全量约 73 credits，免费额度 200 足够；
# 关(false)则只拉榜单/强化/装备，约 3 credits，详情改为按需懒加载。
FETCH_DETAILS=true

# 小程序实际请求的接口域名（仅作记录，真实配置在小程序端 request 合法域名）
API_BASE=https://api.yourdomain.cn
